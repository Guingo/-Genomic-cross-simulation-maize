# ============================================================
# Classificar linhagens em dois grupos genÃĐticos usando PCA + k-means
# Entrada:
# - sim_inputs_real.rds
# SaÃ­das:
# - grupos_linhagens_A_B.rds
# - pca_grupos_linhagens_A_B.rds
# - PCA_grupos_geneticos_A_B.png
# ============================================================

library(ggplot2)
set.seed(123)

# ------------------------------------------------------------
# 1. Carregar entradas
# ------------------------------------------------------------

sim_inputs_real <- readRDS("sim_inputs_real.rds")

geno <- sim_inputs_real$geno
geno <- as.matrix(geno)

# ------------------------------------------------------------
# 2. Remover marcadores sem variÃĒncia
# ------------------------------------------------------------

var_snp <- apply(geno, 2, var, na.rm = TRUE)

snps_validos <- names(var_snp)[
  !is.na(var_snp) & var_snp > 0
]

geno_pca <- geno[, snps_validos, drop = FALSE]

# ------------------------------------------------------------
# 3. Padronizar matriz de marcadores
# ------------------------------------------------------------

geno_scaled <- scale(
  geno_pca,
  center = TRUE,
  scale = TRUE
)

col_ok <- apply(geno_scaled, 2, function(x) all(is.finite(x)))
geno_scaled <- geno_scaled[, col_ok, drop = FALSE]

cat("\nDimensÃĢo final usada na PCA:\n")
print(dim(geno_scaled))

# ------------------------------------------------------------
# 4. PCA
# ------------------------------------------------------------

pca_geno <- prcomp(
  geno_scaled,
  center = FALSE,
  scale. = FALSE
)

var_exp <- summary(pca_geno)$importance[2, 1:5] * 100

cat("\nVariÃĒncia explicada pelos cinco primeiros PCs (%):\n")
print(round(var_exp, 2))

pca_df <- data.frame(
  Linhagem = rownames(geno),
  PC1 = pca_geno$x[, 1],
  PC2 = pca_geno$x[, 2],
  stringsAsFactors = FALSE
)

# ------------------------------------------------------------
# 5. ClassificaÃ§ÃĢo em dois grupos genÃĐticos
# ------------------------------------------------------------

km <- kmeans(
  pca_df[, c("PC1", "PC2")],
  centers = 2,
  nstart = 50
)

pca_df$Grupo <- paste0("Grupo_", km$cluster)

pca_df$Grupo <- dplyr::recode(
  pca_df$Grupo,
  "Grupo_1" = "A",
  "Grupo_2" = "B"
)

grupos_linhagens <- pca_df[, c("Linhagem", "Grupo")]

cat("\nNÃšmero de linhagens por grupo:\n")
print(table(grupos_linhagens$Grupo))

# ------------------------------------------------------------
# 6. GrÃĄfico da PCA
# ------------------------------------------------------------

plot_grupos <- ggplot(
  pca_df,
  aes(x = PC1, y = PC2, color = Grupo)
) +
  geom_point(size = 3, alpha = 0.85) +
  theme_classic(base_size = 14) +
  labs(
    x = paste0("PC1 (", round(var_exp[1], 2), "%)"),
    y = paste0("PC2 (", round(var_exp[2], 2), "%)"),
    color = "Grupo"
  )

print(plot_grupos)
